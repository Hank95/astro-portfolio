---
import { intro, siteConfig } from '@/data/content';
---

<section
  id="intro"
  class="relative pt-36 md:pt-40 pb-12 min-h-[70vh] flex items-center overflow-x-clip"
>
  <!-- Decorative gradient -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-accent/[0.03] blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="content-container w-full">
    <h1 class="text-3xl sm:text-display text-text text-balance hero-stagger" style="--delay: 0">
      {intro.headline}
    </h1>

    <p class="mt-3 text-subtitle text-text-muted hero-stagger" style="--delay: 1">
      {intro.subtitle}
    </p>

    <p class="mt-4 max-w-xl text-body text-text-muted leading-relaxed hero-stagger" style="--delay: 2">
      {intro.description}
    </p>

    <p class="mt-2 text-small text-text-subtle flex items-center gap-1.5 hero-stagger" style="--delay: 3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-3.5 h-3.5 shrink-0"
        aria-hidden="true"
      >
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
        <circle cx="12" cy="10" r="3"></circle>
      </svg>
      {intro.location}
    </p>

    <div class="mt-8 flex items-center gap-4 flex-wrap hero-stagger" style="--delay: 4">
      <a
        href="#work"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg
               bg-text text-bg text-small font-medium
               hover:opacity-90 transition-opacity
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
      >
        View Work
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <polyline points="19 12 12 19 5 12"></polyline>
        </svg>
      </a>

      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg
               border border-border text-text text-small font-medium
               hover:border-border-hover hover:bg-bg-subtle transition-colors
               focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
      >
        Get in Touch
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-4 h-4"
          aria-hidden="true"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
      </a>
    </div>

    <!-- Inline social links -->
    <div class="mt-6 flex items-center gap-4 hero-stagger" style="--delay: 5">
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="text-text-subtle hover:text-text transition-colors" aria-label="GitHub">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </a>
      <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer" class="text-text-subtle hover:text-text transition-colors" aria-label="LinkedIn">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
      <a href={`mailto:${siteConfig.email}`} class="text-text-subtle hover:text-text transition-colors" aria-label="Email">
        <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .hero-stagger {
    opacity: 0;
    transform: translateY(12px);
    animation: hero-fade-in 0.6s ease forwards;
    animation-delay: calc(var(--delay, 0) * 80ms + 100ms);
  }

  @keyframes hero-fade-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-stagger {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
