---
interface Props {
  status: 'live' | 'building' | 'professional';
  class?: string;
}

const { status, class: className } = Astro.props;

const config = {
  live: {
    label: 'Live',
    classes: 'text-status-live bg-status-live/10',
  },
  building: {
    label: 'Building',
    classes: 'text-status-building bg-status-building/10',
  },
  professional: {
    label: 'Professional',
    classes: 'text-status-professional bg-status-professional/10',
  },
};

const { label, classes } = config[status];
---

<span
  class:list={[
    'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium font-mono',
    classes,
    className,
  ]}
>
  {label}
</span>
