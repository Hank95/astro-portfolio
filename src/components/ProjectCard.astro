---
import type { Project } from '@/data/projects';
import StatusBadge from './StatusBadge.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { slug, title, subtitle, techStack, status, links } = project;
---

<a
  href={`/projects/${slug}`}
  class="group block rounded-xl border border-border bg-bg p-4 sm:p-6 shadow-card
         transition-all duration-200
         hover:-translate-y-0.5 hover:shadow-card-hover hover:border-border-hover
         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <h3
        class="text-subtitle text-text truncate"
        transition:name={`project-title-${slug}`}
      >
        {title}
      </h3>
      <p class="mt-1 text-small text-text-muted line-clamp-2">{subtitle}</p>
    </div>

    <!-- Quick-link icons (rendered as buttons inside the card link) -->
    <div class="flex items-center gap-2 shrink-0 text-text-subtle">
      {links.live && (
        <span
          role="link"
          data-href={links.live}
          aria-label={`${title} live site`}
          class="quick-link p-1 rounded hover:text-accent transition-colors cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4"
            aria-hidden="true"
          >
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
          </svg>
        </span>
      )}
      {links.github && (
        <span
          role="link"
          data-href={links.github}
          aria-label={`${title} GitHub repository`}
          class="quick-link p-1 rounded hover:text-accent transition-colors cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4"
            aria-hidden="true"
          >
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
        </span>
      )}
      {links.appStore && (
        <span
          role="link"
          data-href={links.appStore}
          aria-label={`${title} App Store`}
          class="quick-link p-1 rounded hover:text-accent transition-colors cursor-pointer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4"
            aria-hidden="true"
          >
            <path d="M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z"></path>
            <path d="M10 2c1 .5 2 2 2 5"></path>
          </svg>
        </span>
      )}
    </div>
  </div>

  <div class="mt-4 flex items-center justify-between gap-3">
    <p class="text-xs font-mono text-text-subtle truncate">
      {techStack.join(' · ')}
    </p>
    <StatusBadge status={status} />
  </div>
</a>

<script>
  document.querySelectorAll('.quick-link').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const href = (el as HTMLElement).dataset.href;
      if (href) window.open(href, '_blank', 'noopener,noreferrer');
    });
  });
</script>
