---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { resume } from '@/data/resume';

// Generate JSON-LD structured data
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://henrypendleton.com/resume#person",
  name: resume.name,
  jobTitle: resume.title,
  description: resume.summary,
  email: `mailto:${resume.email}`,
  telephone: resume.phone,
  url: "https://henrypendleton.com",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Charleston",
    addressRegion: "SC",
    addressCountry: "US",
  },
  sameAs: [
    `https://github.com/${resume.github}`,
    "https://linkedin.com/in/henrypendleton",
  ],
  worksFor: {
    "@type": "Organization",
    name: resume.professionalExperience[0].company,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Charleston",
      addressRegion: "SC",
      addressCountry: "US",
    },
  },
  alumniOf: resume.education.map((edu) => ({
    "@type": "EducationalOrganization",
    name: edu.school,
    address: {
      "@type": "PostalAddress",
      addressLocality: edu.location.split(", ")[0],
      addressRegion: edu.location.split(", ")[1],
      addressCountry: "US",
    },
  })),
  knowsAbout: [
    ...resume.technicalSkills.languages,
    ...resume.technicalSkills.webDevelopment,
    ...resume.technicalSkills.databases,
    ...resume.technicalSkills.martech,
  ],
};

const profilePageSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  mainEntity: {
    "@id": "https://henrypendleton.com/resume#person",
  },
  dateModified: new Date().toISOString().split("T")[0],
  description: `Professional resume for ${resume.name}, ${resume.title}`,
};
---

<BaseLayout
  title="Resume - Henry Pendleton"
  description="Henry Pendleton's resume. MarTech Software Engineer building web and marketing technology solutions at Maymont Homes."
  structuredData={[personSchema, profilePageSchema] as any}
>

  <main id="main" class="flex-1 pt-24 pb-8 px-4">
    <div class="resume-container max-w-4xl mx-auto bg-bg-subtle rounded-lg shadow-2xl shadow-black/20 overflow-hidden">

      <!-- Header -->
      <header class="resume-header px-8 py-8 border-b border-border">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
          <!-- Name and title -->
          <div>
            <h1 class="text-4xl font-bold text-text tracking-tight">
              {resume.name}
            </h1>
            <p class="mt-2 text-xl text-accent resume-accent font-medium">
              {resume.title}
            </p>
            <p class="mt-4 text-text-muted resume-muted max-w-lg leading-relaxed">
              {resume.summary}
            </p>
          </div>

          <!-- Contact info -->
          <div class="flex flex-col gap-2 text-sm shrink-0">
            <a
              href={`mailto:${resume.email}`}
              class="flex items-center gap-2 text-text-muted resume-muted hover:text-accent transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              {resume.email}
            </a>
            <a
              href={`tel:${resume.phone}`}
              class="flex items-center gap-2 text-text-muted resume-muted hover:text-accent transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
              {resume.phone}
            </a>
            <span class="flex items-center gap-2 text-text-muted resume-muted">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              {resume.location}
            </span>
            <a
              href={`https://github.com/${resume.github}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-text-muted resume-muted hover:text-accent transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
              </svg>
              github.com/{resume.github}
            </a>
          </div>
        </div>

        <!-- Download/Print button -->
        <button
          id="print-resume-btn"
          class="no-print mt-6 inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-bg bg-text rounded-md hover:bg-text-muted transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download Resume
        </button>
      </header>

      <!-- Main content -->
      <div class="px-8 py-8 space-y-10">

        <!-- Technical Skills -->
        <section>
          <h2 class="resume-section-title text-lg font-semibold text-text uppercase tracking-wider border-b border-border pb-2 mb-6">
            Technical Skills
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {Object.entries(resume.technicalSkills).map(([category, skills]) => (
              <div>
                <h3 class="text-sm font-medium text-text-muted resume-muted uppercase tracking-wide mb-3">
                  {category.replace(/([A-Z])/g, ' $1').trim()}
                </h3>
                <div class="flex flex-wrap gap-2">
                  {skills.map((skill) => (
                    <span class="resume-skill-tag px-2 py-1 text-xs font-mono bg-bg-muted border border-border rounded text-text-muted resume-muted">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Professional Experience -->
        <section>
          <h2 class="resume-section-title text-lg font-semibold text-text uppercase tracking-wider border-b border-border pb-2 mb-6">
            Professional Experience
          </h2>
          <div class="space-y-6">
            {resume.professionalExperience.map((exp) => (
              <div class="resume-item">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
                  <div>
                    <h3 class="text-lg font-semibold text-text">
                      {exp.title}
                    </h3>
                    <p class="text-text-muted resume-muted">
                      {exp.company} · {exp.location}
                    </p>
                  </div>
                  <span class="text-sm font-mono text-text-subtle resume-subtle shrink-0">
                    {exp.date}
                  </span>
                </div>

                {exp.projects.map((project) => (
                  <div class="mt-4 pl-4 border-l-2 border-border">
                    <h4 class="text-sm font-semibold text-accent resume-accent mb-2">
                      {project.name}
                    </h4>
                    <ul class="space-y-1">
                      {project.description.map((desc) => (
                        <li class="text-sm text-text-muted resume-muted leading-relaxed flex gap-2">
                          <span class="text-text-subtle resume-subtle shrink-0">—</span>
                          <span>{desc}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            ))}
          </div>
        </section>

        <!-- Technical Projects -->
        <section>
          <h2 class="resume-section-title text-lg font-semibold text-text uppercase tracking-wider border-b border-border pb-2 mb-6">
            Technical Projects
          </h2>
          <div class="space-y-6">
            {resume.technicalProjects.map((project) => (
              <div class="resume-item">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 mb-2">
                  <h3 class="text-lg font-semibold text-text">
                    {project.name}
                  </h3>
                  <div class="flex items-center gap-3 text-sm">
                    {project.github && (
                      <a
                        href={project.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-text-muted resume-muted hover:text-accent transition-colors"
                      >
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                        </svg>
                        <span class="hidden sm:inline">Code</span>
                      </a>
                    )}
                    {project.demo && (
                      <a
                        href={project.demo}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-text-muted resume-muted hover:text-accent transition-colors"
                      >
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                          <polyline points="15 3 21 3 21 9"></polyline>
                          <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                        <span class="hidden sm:inline">Live</span>
                      </a>
                    )}
                    {project.website && (
                      <a
                        href={project.website}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-text-muted resume-muted hover:text-accent transition-colors"
                      >
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                          <polyline points="15 3 21 3 21 9"></polyline>
                          <line x1="10" y1="14" x2="21" y2="3"></line>
                        </svg>
                        <span class="hidden sm:inline">Site</span>
                      </a>
                    )}
                  </div>
                </div>
                <ul class="space-y-1 pl-4 border-l-2 border-border">
                  {project.description.map((desc) => (
                    <li class="text-sm text-text-muted resume-muted leading-relaxed flex gap-2">
                      <span class="text-text-subtle resume-subtle shrink-0">—</span>
                      <span>{desc}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>

        <!-- Prior Experience -->
        <section>
          <h2 class="resume-section-title text-lg font-semibold text-text uppercase tracking-wider border-b border-border pb-2 mb-6">
            Prior Experience
          </h2>
          <div class="space-y-4">
            {resume.priorExperience.map((exp) => (
              <div class="resume-item">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-2">
                  <div>
                    <h3 class="text-base font-semibold text-text">
                      {exp.title}
                    </h3>
                    <p class="text-sm text-text-muted resume-muted">
                      {exp.company} · {exp.location}
                    </p>
                  </div>
                  <span class="text-sm font-mono text-text-subtle resume-subtle shrink-0">
                    {exp.date}
                  </span>
                </div>
                <ul class="space-y-1 pl-4 border-l-2 border-border">
                  {exp.description.map((desc) => (
                    <li class="text-sm text-text-muted resume-muted leading-relaxed flex gap-2">
                      <span class="text-text-subtle resume-subtle shrink-0">—</span>
                      <span>{desc}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </section>

        <!-- Education -->
        <section>
          <h2 class="resume-section-title text-lg font-semibold text-text uppercase tracking-wider border-b border-border pb-2 mb-6">
            Education
          </h2>
          <div class="space-y-4">
            {resume.education.map((edu) => (
              <div class="resume-item flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
                <div>
                  <h3 class="text-base font-semibold text-text">
                    {edu.school}
                  </h3>
                  <p class="text-sm text-text-muted resume-muted">
                    {edu.degree}
                  </p>
                  <p class="text-sm text-text-subtle resume-subtle">
                    {edu.location}
                  </p>
                </div>
                <span class="text-sm font-mono text-text-subtle resume-subtle shrink-0">
                  {edu.date}
                </span>
              </div>
            ))}
          </div>
        </section>

      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @media print {
    @page {
      margin: 0.5in;
      size: letter;
    }
    body {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    /* Hide site header, footer, nav, and fixed elements */
    header:not(.resume-header),
    footer,
    nav,
    [class*="fixed"] {
      display: none !important;
    }
    .resume-container {
      background: white !important;
      color: #1a1a1a !important;
      box-shadow: none !important;
      max-width: 100% !important;
      padding: 0 !important;
    }
    .resume-container * {
      color: #1a1a1a !important;
      border-color: #e5e5e5 !important;
    }
    .resume-header {
      border-bottom-color: #e5e5e5 !important;
    }
    .resume-section-title {
      color: #1a1a1a !important;
      border-bottom-color: #e5e5e5 !important;
    }
    .resume-accent {
      color: #2563eb !important;
    }
    .resume-muted {
      color: #525252 !important;
    }
    .resume-subtle {
      color: #737373 !important;
    }
    .resume-skill-tag {
      background: #f5f5f5 !important;
      border-color: #e5e5e5 !important;
    }
    .resume-item {
      background: transparent !important;
      border-color: #e5e5e5 !important;
    }
    .no-print {
      display: none !important;
    }
    a {
      text-decoration: none !important;
    }
  }
</style>

<script>
  const btn = document.getElementById('print-resume-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      window.print();
    });
  }
</script>
